    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "^4.0.14",
    "vitest-axe": "^0.1.0"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "name": "react-template-astro",
  "pnpm": {
    "overrides": {
      "path-to-regexp@6.1.0": "8.4.2",
      "yaml@2.7.1": "2.8.3"
    }
  },
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true astro build",
    "build": "astro check && astro build",
    "check": "pnpm lint:es:check && pnpm lint:ts && pnpm format:check && pnpm test -- --run",
    "commitlint": "commitlint --edit",
    "coverage": "vitest run --coverage",
    "dev": "astro dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:es": "eslint . --fix",
    "lint:es:check": "eslint .",
    "lint:ts": "astro check",
    "prepare": "husky",
    "preview": "astro preview",
    "start": "astro preview --host 0.0.0.0",
    "test": "vitest",
    "test:browser": "vitest --browser",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ui": "vitest --ui"
  },
  "type": "module",
  "version": "0.0.0"
}
