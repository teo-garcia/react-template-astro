{
  "extends": "@teo-garcia/tsconfig-shared/vite-react",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    },
    "jsxImportSource": "react",
    "types": ["vite/client", "vitest/globals", "@vitest/browser-playwright"]
  },
  "include": [
    "src/**/*.astro",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/env.d.ts",
    "astro.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "e2e/**/*.ts"
  ]
}
