---
import '~/styles/app.css'
import { ClientRouter } from 'astro:transitions'
import { Providers } from '~/components/providers'
import { getCanonicalUrl, siteMetadata } from '~/lib/seo'

// eslint-disable-next-line unicorn/prevent-abbreviations -- Astro uses Props by convention
interface Props {
  title: string
  description?: string
}

const { title, description = siteMetadata.description } = Astro.props
const canonicalUrl = getCanonicalUrl(Astro.url.pathname)
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='description' content={description} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:type' content='website' />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:site_name' content={siteMetadata.name} />
    <meta name='twitter:card' content='summary' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <link rel='canonical' href={canonicalUrl} />
    <link rel='icon' href='/favicon.svg' type='image/svg+xml' />
    <link rel='sitemap' href='/sitemap-index.xml' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap'
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Providers client:load>
      <main id='main-content'>
        <slot />
      </main>
    </Providers>
  </body>
</html>
